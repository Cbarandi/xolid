# Private access (required for /bots and /admin)
XOLID_PRIVATE_USERNAME=
XOLID_PRIVATE_PASSWORD_HASH=
XOLID_SESSION_SECRET=
# Generate hash: npm run hash:private-password -- "your-password"

# Admin BLOCK/VIXION link targets: edit lib/admin-links.ts (ADMIN_LINKS)

# Analytics (Plausible)
# Public domain to attribute visits to (defaults to xolid.ai)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=xolid.ai
# Public script URL (defaults to the current XOLID Plausible script)
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/pa-0Lv0_7Zwm6C8QH5JFdLoS.js

# Supabase (server-side waitlist + trading bots persistence)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Run supabase/migrations/*.sql in the Supabase SQL editor before using Bots.

# Optional: Binance public Spot API base (defaults to https://api.binance.com)
# BINANCE_PUBLIC_API_BASE=https://api.binance.com

# Contact form (Resend + optional Supabase `contacts` table)
RESEND_API_KEY=re_xxxxxxxx
# Verified sender in Resend (e.g. XOLID <hello@xolid.ai>)
CONTACT_FROM_EMAIL="XOLID <hello@xolid.ai>"
# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=hello@xolid.ai
